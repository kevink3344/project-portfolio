# Server environment variables
# Copy this file to .env and fill in your values. Never commit .env to source control.

PORT=3001

# Azure SQL Server connection
DB_SERVER=your-server.database.windows.net
DB_NAME=your-database-name
DB_USER=your-db-username
DB_PASSWORD=your-db-password
DB_PORT=1433

# JWT — generate a strong random secret, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME

# Admin credentials
# ADMIN_PASSWORD_HASH must be a bcrypt hash of your chosen password.
# Generate one with: node -e "const b=require('bcryptjs'); b.hash('yourpassword',12).then(console.log)"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=CHANGE_ME

# Allowed origin for CORS (your Vite dev server)
CLIENT_ORIGIN=http://localhost:5173

# Use SQLite instead of Azure SQL (set to 'true' in both local and production)
# DB file defaults to server/db/portfolio.sqlite — override with SQLITE_PATH if needed.
# USE_SQLITE=true
# SQLITE_PATH=/custom/path/portfolio.sqlite
